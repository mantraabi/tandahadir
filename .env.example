# ─── Database ───
# DATABASE_URL = pooler connection (port 6543) — for runtime queries on serverless
# Tambahkan ?pgbouncer=true&connection_limit=1 untuk Supabase pooler
DATABASE_URL="postgresql://postgres.xxx:[PASSWORD]@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL = direct connection (port 5432) — for Prisma migrations only
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres"

# ─── NextAuth (REQUIRED) ───
# Generate via: npx auth secret  OR  openssl rand -base64 32
AUTH_SECRET="your-random-secret-min-32-chars"

# Public app URL — used for QR scan URLs (must match deployment domain)
# In production: https://your-app.vercel.app
# In local dev: http://localhost:3000 (or LAN IP for testing on real phones)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Optional ───
# Cron job secret (for /api/cron/* endpoints)
CRON_SECRET=""

# Resend API key (for forgot-password emails — not yet wired up)
RESEND_API_KEY=""
